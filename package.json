    "axios": "^1.7.9",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "viem": "^2.21.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
